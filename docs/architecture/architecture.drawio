<mxfile host="app.diagrams.net" type="device">
  <diagram name="AI Security Analyst" id="ai-sec-analyst-arch">
    <mxGraphModel dx="1100" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Group containers (drawn first = behind) -->
        <mxCell id="grp_wl" value="Workload and member accounts" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="320" height="120" as="geometry" />
        </mxCell>
        <mxCell id="grp_sec" value="Security Tooling account (delegated admin)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f7fbff;strokeColor=#4a7ebb;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="1040" height="1060" as="geometry" />
        </mxCell>

        <!-- Workload -->
        <mxCell id="act" value="AWS activity and resources" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="70" y="85" width="260" height="50" as="geometry" />
        </mxCell>

        <!-- Detection row -->
        <mxCell id="gd" value="GuardDuty" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
