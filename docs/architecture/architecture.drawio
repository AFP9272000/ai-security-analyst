        </mxCell>
        <mxCell id="ct" value="CloudTrail" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="520" y="250" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- EventBridge -->
        <mxCell id="eb" value="EventBridge" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="300" y="350" width="180" height="55" as="geometry" />
        </mxCell>

        <!-- Enricher + lake + glue + sagemaker -->
        <mxCell id="enr" value="Enricher Lambda" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
