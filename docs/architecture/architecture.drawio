        <!-- KB + Agent + guardrail + tools -->
        <mxCell id="kb" value="Bedrock Knowledge Base&#10;Aurora pgvector (scale-to-zero)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
